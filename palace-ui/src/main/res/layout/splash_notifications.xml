<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/splashNotificationsImage"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:layout_margin="64dp"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:src="@drawable/bell_on" />

        <TextView
            android:id="@+id/splashNotificationsText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="16dp"
            android:gravity="center"
            android:text="@string/splashNotificationsText"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/splashNotificationsButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="32dp"
            android:gravity="center"
            android:minHeight="96dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/splashNotificationsAllow"
                style="@style/Palace.Button.Contained.Medium"
                android:layout_width="128dp"
                android:layout_height="match_parent"
                android:layout_weight="1.0"
                android:text="@string/splashNotificationsAllow" />

            <Space
                android:layout_width="32dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/splashNotificationsSkip"
                android:layout_width="128dp"
                android:layout_height="match_parent"
                android:layout_weight="1.0"
                android:text="@string/splashNotificationsSkip" />

        </LinearLayout>

        <TextView
            android:id="@+id/splashNotificationsHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="64dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/splashNotificationsTextHint"
            android:textSize="14sp"
            android:textStyle="italic" />

    </LinearLayout>

</ScrollView>
